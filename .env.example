# FRIDAY App Configuration

# App Environment
VITE_APP_NAME=FRIDAY
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_CHAT=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_EXPORT=false

# ===== Azure OpenAI Configuration =====
# Get these from your Azure OpenAI resource in Azure Portal
VITE_AZURE_OPENAI_KEY=your_azure_openai_api_key_here
VITE_AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
VITE_AZURE_OPENAI_DEPLOYMENT=your_deployment_id_here

# ===== MCP Server Configuration (Optional) =====
# For Grow MCP integration (investment insights)
# Leave empty to use mock data
VITE_MCP_ENDPOINT=http://localhost:8000/mcp
VITE_GROW_MCP_KEY=your_grow_mcp_api_key_here

# ===== Notification Configuration =====
# Browser notifications are enabled by default
# Set to false to disable push notifications
VITE_ENABLE_NOTIFICATIONS=true

# ===== Legacy/Future API Endpoints =====
# VITE_API_URL=http://localhost:3000/api
# VITE_AI_API_URL=https://api.openai.com/v1
